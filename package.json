{
  "name": "epoch",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --silent",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run e2e",
    "seed": "python3 scripts/seed.py",
    "e2e": "playwright test",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@terminal3/ecdsa_vc": "^0.1.34",
    "@terminal3/t3n-sdk": "^3.7.0",
    "@terminal3/vc_core": "^0.0.37",
    "@terminal3/verify_vc": "^0.0.38",
    "canvas-confetti": "^1.9.3",
    "lucide-react": "^0.344.0",
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/canvas-confetti": "^1.6.4",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.21.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "js-yaml": "^4.2.0",
    "ws": "^8.21.0",
    "esbuild": "^0.25.0",
    "vite": "^6.4.3"
  }
