# =========================================================================
# EPOCH Dead-Man's Switch - Environment Variables Configuration Template
# =========================================================================
#
# HOW TO USE:
# 1. Copy this template to create a local environment file:
#    - For local development: Copy to `.env.local` (recommended, git-ignored)
#    - For production environment: Copy to `.env.production` or set directly
#      as environment variables in your deployment dashboard (e.g., Vercel).
# 2. DO NOT commit your `.env` or `.env.local` files containing real secrets.
#
# DISTINGUISHING ENVIRONMENTS (Production vs. Local):
# - Local Dev: Set `NODE_ENV=development` and use `NEXT_PUBLIC_ENCLAVE_URL=http://localhost:3000`
# - Production: Set `NODE_ENV=production` and update `NEXT_PUBLIC_ENCLAVE_URL` to your live domain:
#   `NEXT_PUBLIC_ENCLAVE_URL=https://epoch.edycu.dev`
#
# =========================================================================

# ── Core Next.js Config ──────────────────────────────────────
# Local development port (default: 3000)
PORT=3000

# Environment type (development, production)
# Set to 'production' for live deployments.
NODE_ENV=development

# ── Terminal 3 TEE Enclave Telemetry ──────────────────────────
# TEE Enclave measurement value (SHA-256 hash of the compiled WASM contract).
# Generated during contract compile (cargo build --target wasm32-wasi).
NEXT_PUBLIC_ENCLAVE_MEASUREMENT=sha256-5b323c6f14028bc9ef2be91fe5d3a5bc382ff2fcf930b2da96cd459d871be364

# TEE Enclave deployment endpoint.
# - Local Dev: http://localhost:3000 (standard local proxy route)
# - Production: https://epoch.edycu.dev (your live custom production domain)
NEXT_PUBLIC_ENCLAVE_URL=http://localhost:3000

